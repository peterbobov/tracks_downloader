# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Telegram API Configuration (for Telethon)
# Get these from https://my.telegram.org
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE_NUMBER=+1234567890

# External Bot Configuration
EXTERNAL_BOT_USERNAME=@your_external_bot_username

# Odesli/song.link API key (for Spotify → Tidal URL conversion)
# Get one at https://odesli.co — higher rate limits with a paid key
ODESLI_API_KEY=

# Download Configuration
DOWNLOAD_FOLDER=./downloads  # Legacy parameter, kept for compatibility
MUSIC_LIBRARY_PATH=./music   # Main music library path where tracks are organized by playlist
DELAY_BETWEEN_REQUESTS=3
MAX_RETRIES=3
REQUEST_TIMEOUT=30
FLOOD_WAIT_MULTIPLIER=1.5